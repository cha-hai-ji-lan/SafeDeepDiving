{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "safe-deep-diving",
  "version": "0.0.25",
  "identifier": "com.chaHaiJiLan.safe-deep-diving",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "safeDeepDiving",
        "width": 1280,
        "height": 720,
        "minWidth": 512,
        "minHeight": 288,
        "decorations": false,
        "shadow": false,
        "center": true,
        "transparent": true,
        "visible": false,
        "label": "main"
      },
      {
        "width": 640,
        "height": 400,
        "title": "SafeDeepDiving-SplashScreen",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "shadow": false,
        "skipTaskbar": true,
        "url": "/page/splashScreen.html",
        "label": "splashScreen"

      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/**/*"
    ]
  }
}